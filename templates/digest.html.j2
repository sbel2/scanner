<!doctype html>
<html>
<head>
<meta charset="utf-8">
<style>
body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; color: #1a1a1a; max-width: 680px; margin: 0 auto; padding: 24px; }
h1 { font-size: 22px; margin-bottom: 4px; }
.subtitle { color: #666; font-size: 13px; margin-bottom: 24px; }
.category { font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: #888; margin-top: 28px; margin-bottom: 8px; border-bottom: 1px solid #eee; padding-bottom: 4px; }
.item { padding: 14px 0; border-bottom: 1px solid #f0f0f0; }
.title { font-size: 16px; font-weight: 600; margin: 0 0 4px 0; }
.title a { color: #0066cc; text-decoration: none; }
.title a:hover { text-decoration: underline; }
.meta { font-size: 12px; color: #666; margin-bottom: 6px; }
.score { display: inline-block; background: #eaf3ff; color: #0050a0; padding: 1px 6px; border-radius: 3px; font-weight: 600; font-size: 11px; margin-right: 6px; }
.deadline { color: #c0392b; font-weight: 500; }
.deadline.soon { color: #c0392b; font-weight: 700; }
.reasoning { font-size: 13px; color: #444; margin-top: 4px; line-height: 1.45; }
.eligibility { font-size: 11px; color: #888; margin-top: 4px; font-style: italic; }
.footer { margin-top: 32px; font-size: 11px; color: #999; border-top: 1px solid #eee; padding-top: 12px; }
.empty { color: #999; font-style: italic; }
</style>
</head>
<body>
<h1>Daily AI Opportunities</h1>
<div class="subtitle">{{ today }} · {{ total }} new, top {{ items|length }} shown · scored against your alignment docs</div>

{% if not items %}
  <p class="empty">No new opportunities cleared the bar today.</p>
{% endif %}

{% for category, group in grouped.items() %}
  <div class="category">{{ category }}</div>
  {% for s in group %}
  <div class="item">
    <div class="title"><a href="{{ s.opportunity.url }}">{{ s.opportunity.title }}</a></div>
    <div class="meta">
      <span class="score">{{ "%.1f"|format(s.final_score) }}/10</span>
      <span>{{ s.opportunity.source }}</span>
      {% if s.opportunity.location %} · <span>{{ s.opportunity.location }}</span>{% endif %}
      {% if s.opportunity.deadline %}
        · <span class="deadline{% if s.deadline_soon %} soon{% endif %}">deadline {{ s.opportunity.deadline }}</span>
      {% endif %}
    </div>
    <div class="reasoning">{{ s.alignment.reasoning }}</div>
    {% if s.eligibility.eligible == "unclear" %}
      <div class="eligibility">eligibility: unclear — {{ s.eligibility.reason }}</div>
    {% endif %}
  </div>
  {% endfor %}
{% endfor %}

<div class="footer">
  Reply to this email with your reactions (e.g. "more like #2", "fewer hackathons") and the scanner will tune over time.
</div>
</body>
</html>
