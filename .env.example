# ============================================================
#  SCANNER — API Keys
#  Copy this file to .env and fill in your keys.
#  Run `python -m scanner init` to do this automatically.
# ============================================================

# ------------------------------------------------------------
#  CLAUDE AUTH (required — choose one)
# ------------------------------------------------------------

# Option 1 — RECOMMENDED if you have Claude Pro or Max
# Uses your existing subscription. No extra billing.
# Steps:
#   1. Install Claude Code: https://claude.ai/download
#   2. Open your terminal and run: claude setup-token
#   3. Paste the token it gives you below.
# The token lasts 1 year and is designed for automated/headless use.
CLAUDE_CODE_OAUTH_TOKEN=

# Option 2 — Anthropic API key (pay-per-token billing)
# Use this if you do not have a Claude Pro/Max subscription.
# Get a key at: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...

# ------------------------------------------------------------
#  TAVILY (required for web search / long-tail discovery)
# ------------------------------------------------------------
# Get yours at: https://app.tavily.com/  (1,000 free searches/month)
TAVILY_API_KEY=tvly-...

# ------------------------------------------------------------
#  RESEND (required for sending the daily digest email)
# ------------------------------------------------------------
# Get yours at: https://resend.com/  (free tier available)
# Tip: use "onboarding@resend.dev" as EMAIL_FROM to skip domain verification
RESEND_API_KEY=re_...

# ------------------------------------------------------------
#  Optional overrides (can also be set in mission.yaml)
# ------------------------------------------------------------
# EMAIL_TO=you@example.com
# EMAIL_FROM=onboarding@resend.dev

# Set to 1 for a dry run — prints what would be sent, no email delivered
SCANNER_DRY_RUN=0

# Number of top opportunities to include in each digest
SCANNER_TOP_N=8
