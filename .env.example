# ============================================================
#  SCANNER — API Keys
#  Copy this file to .env and fill in your keys.
#  Run `python -m scanner init` to do this automatically.
# ============================================================

# Anthropic API key — required for LLM scoring and eligibility checks
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Tavily API key — required for web search (long-tail opportunity discovery)
# Get yours at: https://app.tavily.com/  (1,000 free searches/month)
TAVILY_API_KEY=tvly-...

# Resend API key — required for sending the daily digest email
# Get yours at: https://resend.com/  (free tier available)
# Tip: use "onboarding@resend.dev" as EMAIL_FROM to skip domain verification
RESEND_API_KEY=re_...

# ============================================================
#  Optional overrides (these can also be set in mission.yaml)
# ============================================================
# EMAIL_TO=you@example.com
# EMAIL_FROM=onboarding@resend.dev

# Set to 1 to do a dry run (no email sent, prints what would be sent)
SCANNER_DRY_RUN=0

# Number of top opportunities to include in each digest
SCANNER_TOP_N=8
